rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupData) {
      return isSignedIn() && request.auth.uid in groupData.memberIds;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(resource.data);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.createdBy
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isGroupMember(resource.data) ||
        (isSignedIn()
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.auth.uid in request.resource.data.memberIds);
      allow delete: if false;

      match /expenses/{expenseId} {
        allow read: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
        allow create: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
          && request.auth.uid == request.resource.data.createdBy;
        allow update, delete: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
      }

      match /settlements/{settlementId} {
        allow read: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
        allow create: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
          && request.auth.uid == request.resource.data.fromUid;
        allow update: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
          && request.auth.uid == resource.data.toUid;
        allow delete: if false;
      }
    }
  }
}
